rules_version = '2';

// ──────────────────────────────────────────────────────────────
//  CashFlow — Firestore Security Rules
//
//  HOW TO APPLY:
//   1. Firebase Console → Firestore Database → "Rules" tab
//   2. Delete everything there and paste this whole file
//   3. Click "Publish"
//
//  WHAT IT DOES:
//   Every signed-in user can read & write ONLY the documents under
//   their own user id (users/<their-uid>/...). Nobody can read or
//   write anyone else's data, and unauthenticated access is denied.
//
//  NOTE: A Firebase apiKey is NOT a secret — it is meant to be public.
//  These rules (plus Google sign-in and App Check) are what actually
//  protect your data.
// ──────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // A user owns everything under their own user id.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny all other paths by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
